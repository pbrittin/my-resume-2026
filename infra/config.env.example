# =============================================================================
# config.env.example — copy to config.env and fill in your values
#
# config.env is listed in .gitignore and will NOT be committed to GitHub.
# =============================================================================

# ── AWS ───────────────────────────────────────────────────────────────────────

# Your 12-digit AWS account ID (no dashes)
# Find it: aws sts get-caller-identity --query Account --output text
AWS_ACCOUNT_ID=123456789012

# Region to deploy resources in.
# NOTE: ACM certificates for CloudFront must always be in us-east-1.
# If you set a different region here, setup.sh requests the ACM cert
# in us-east-1 automatically regardless of this value.
AWS_REGION=us-east-1

# ── GitHub ────────────────────────────────────────────────────────────────────

# Your GitHub username (not email, not display name)
GITHUB_USERNAME=your-github-username

# The exact repository name (case-sensitive)
GITHUB_REPO_NAME=aws-resume

# ── S3 Buckets ────────────────────────────────────────────────────────────────

# Bucket that holds your static frontend files (HTML, CSS, JS, images).
# Must be globally unique across all AWS accounts — add a suffix if needed.
S3_BUCKET_NAME=your-resume-site-bucket

# Bucket where SAM uploads Lambda deployment packages before creating the stack.
# Must be globally unique. Keep it separate from the frontend bucket.
SAM_ARTIFACT_BUCKET=your-resume-sam-artifacts

# ── SAM / CloudFormation ──────────────────────────────────────────────────────

# Name of the CloudFormation stack SAM will create for the backend.
STACK_NAME=aws-resume-backend

# ── Domain (optional — leave blank to skip ACM certificate setup) ─────────────

# Your registered domain name WITHOUT the www prefix.
# Example: example.com  (not www.example.com)
# Leave empty if you don't have a domain yet — you can re-run setup.sh later.
DOMAIN_NAME=
